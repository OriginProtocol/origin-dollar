# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                              RPC PROVIDERS                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# [Required] RPC URL for mainnet (used for fork tests and deployments)
MAINNET_PROVIDER_URL=

# [Optional] RPC URLs for other networks
# BASE_PROVIDER_URL=
# ARBITRUM_PROVIDER_URL=
SONIC_PROVIDER_URL=https://rpc.soniclabs.com
# HYPEREVM_PROVIDER_URL=
# HOLESKY_PROVIDER_URL=

# [Optional] Beacon chain RPC (used for beacon proof tests)
# BEACON_PROVIDER_URL=

# [Optional] Local node URL (used by `make deploy-local`)
# LOCAL_URL=http://127.0.0.1:8545

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                            FORK BLOCK NUMBERS                                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# [Optional] Pin fork tests to specific block numbers for reproducibility
# BLOCK_NUMBER=
# BASE_BLOCK_NUMBER=
# SONIC_BLOCK_NUMBER=
# HOLESKY_BLOCK_NUMBER=
# PLUME_BLOCK_NUMBER=
# HOODI_BLOCK_NUMBER=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                              EXTERNAL APIS                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# [Optional] Block explorer API keys for contract verification
# ETHERSCAN_API_KEY=
# BASESCAN_API_KEY=
# SONICSCAN_API_KEY=

# [Optional] 1inch API key for swap quotes
# ONEINCH_API_KEY=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                                DEPLOYMENT                                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# [Optional] Deployer address (corresponding to keystore `deployerKey`)
# DEPLOYER_ADDRESS=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          OPENZEPPELIN DEFENDER                               ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# [Optional] Relayer credentials (for automated transactions)
# DEFENDER_API_KEY=
# DEFENDER_API_SECRET=
# HOLESKY_DEFENDER_API_KEY=
# HOLESKY_DEFENDER_API_SECRET=

# [Optional] Team API credentials (for managing Defender Actions)
# DEFENDER_TEAM_KEY=
# DEFENDER_TEAM_SECRET=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                            VALIDATOR KEYS                                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# [Optional] P2P API keys for validator operations
# P2P_MAINNET_API_KEY=
# P2P_HOODI_API_KEY=

# [Optional] AWS credentials for validator key management (IAM user "validator_key_manager")
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# [Optional] AWS credentials for uploading encrypted validator keys to S3 (IAM user "defender_action")
# AWS_ACCESS_S3_KEY_ID=
# AWS_SECRET_S3_ACCESS_KEY=

# [Optional] S3 bucket name: "validator-keys-test" or "validator-keys"
# VALIDATOR_KEYS_S3_BUCKET_NAME=

# [Optional] Master private key encrypted with AWS KMS (for recovering validator keys)
# VALIDATOR_MASTER_ENCRYPTED_PRIVATE_KEY=
